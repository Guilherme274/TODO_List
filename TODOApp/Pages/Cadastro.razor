@page "/"
@inject NavigationManager navigation

<PageTitle>Cadastro</PageTitle>

<div class="body">
    <EditForm Model="@modelUserRequest">
        <div class="form-cadastro">
            <h2 class="form-title">Bem vindo</h2>
            <div class="form-data">                
                <InputText @bind-Value="modelUserRequest.Nome" placeholder="Nome"></InputText>
            </div>

            <div class="form-data">
                <label>Data de Nascimento</label>
                <InputDate @bind-Value="modelUserRequest.DataNascimento" @bind-Value:format="dd-MM-yyyy"></InputDate>
            </div>

            <div class="form-data">                
                <InputText @bind-Value="modelUserRequest.UserName" placeholder="Nome de Usuário"></InputText>
            </div>

            <div class="form-data">                
                <InputText type="email" @bind-Value="modelUserRequest.Email" placeholder="Email"></InputText>
            </div>

            <div class="form-data">                
                <div class="form-data-password">
                    <InputText type="@(showSenha[0] ? "text" : "password")" @bind-Value="modelUserRequest.Senha" placeholder="Senha"></InputText>
                    <button type="button" @onclick="() => ToggleSenha(0)">@(showSenha[0] ? "🙈" : "👁️")</button>
                </div>
            </div>

            <div class="form-data">                
                <div class="form-data-password">
                    <InputText type="@(showSenha[1] ? "text" : "password")" @bind-Value="modelUserRequest.ConfirmarSenha" placeholder="Confirme a Senha"></InputText>
                    <button type="button" @onclick="() => ToggleSenha(1)">@(showSenha[1] ? "🙈" : "👁️")</button>
                </div>
            </div>
            <button class="form-button" type="submit">Cadastrar</button>
            <p class="form-paraLogin">Já possui uma conta? <span><a href="#"
                                                                    @onclick:preventDefault="true"
                                                                    @onclick="TrocarParaLogin">Entrar</a></span></p>
        </div>
    </EditForm>
</div>


@code {
    public bool[] showSenha = new bool [2];
    public UserRequest modelUserRequest = new UserRequest();
    public class UserRequest
    {
        public string Nome { get; set; }
        public string UserName { get; set; }
        public string Email { get; set; }
        public DateOnly DataNascimento { get; set; }
        public string Senha { get; set; }
        public string ConfirmarSenha { get; set; }
    }

    private void TrocarParaLogin(){        
        navigation.NavigateTo("/login");
    }

    private void ToggleSenha(int i){
        showSenha[i] = !showSenha[i];
    }
}